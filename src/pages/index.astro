---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Mona Mayhem</title>
    <style>
      :root {
        --bg: #181825;
        --panel: #232347;
        --accent: #ffb347;
        --muted: #222;
        --error-neon: #ff3bff;
        --focus-neon: #00fff0;
      }
      body { font-family: 'Press Start 2P', monospace; background: var(--bg); color: #fff; margin: 0; padding: 0; }
      .battle-container { max-width: 900px; margin: 2rem auto; background: var(--panel); border-radius: 12px; padding: 2rem; box-shadow: 0 2px 8px #0004; }
      .inputs { display: flex; gap: 1rem; margin-bottom: 1rem; align-items: center; }
      .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0; }
      .inputs input { flex: 1; padding: 0.6rem; font-size: 0.9rem; border-radius: 6px; border: 2px solid transparent; background: #14141a; color: #fff; box-sizing: border-box; }
      .inputs input::placeholder { color: #7a7a9a; }
      .inputs input:focus, .inputs input:focus-visible { outline: none; border-color: var(--accent); box-shadow: 0 0 0 4px rgba(255,179,71,0.06), 0 0 12px rgba(255,179,71,0.06); }
      .inputs input.input-error { border-color: var(--error-neon); box-shadow: 0 0 8px var(--error-neon); background: linear-gradient(90deg, rgba(255,59,255,0.03), rgba(255,59,255,0.01)); }
      .battle-btn { padding: 0.6rem 1.5rem; font-size: 0.95rem; border-radius: 6px; border: none; background: var(--accent); color: #232347; font-weight: bold; cursor: pointer; }
      .battle-btn:focus, .battle-btn:focus-visible { outline: 3px solid rgba(0,255,240,0.12); box-shadow: 0 0 8px var(--focus-neon); }
      .results { margin-top: 2rem; display: flex; gap: 2rem; justify-content: center; align-items: flex-start; }
      .player { flex: 1; min-width: 0; }
      .contrib-grid { display: grid; grid-template-columns: repeat(7, 14px); gap: 2px; margin: 0.5rem 0; }
      .contrib-cell { width: 14px; height: 14px; border-radius: 2px; background: var(--muted); }
      .battle-container h1, .battle-container p { text-align: center; margin: 0 0 0.5rem 0; }
      .vs-badge { font-size: 2rem; font-weight: bold; color: var(--accent); text-align: center; margin: 1rem 0; }
      .error, .loading { color: #ff6b6b; text-align: center; margin-top: 1rem; display: none; }
      .error.is-active { display: block; padding: 0.75rem; border-radius: 8px; border: 1px solid rgba(255,59,255,0.6); color: var(--error-neon); text-shadow: 0 0 8px rgba(255,59,255,0.9); background: linear-gradient(180deg, rgba(255,59,255,0.02), rgba(255,59,255,0.01)); box-shadow: 0 0 12px rgba(255,59,255,0.1); animation: neon-pulse 1.6s infinite alternate; }
      @keyframes neon-pulse { from { box-shadow: 0 0 6px rgba(255,59,255,0.6); } to { box-shadow: 0 0 18px rgba(255,59,255,0.95); } }
      /* Responsive: collapse comparison to single column at 1024px */
      @media (max-width: 1024px) {
        .results { flex-direction: column; align-items: stretch; gap: 1rem; }
        .vs-badge { margin: 0.6rem 0; align-self: center; }
      }
      /* Stack inputs on small screens */
      @media (max-width: 640px) {
        .inputs { flex-direction: column; align-items: stretch; }
        .inputs input, .battle-btn { width: 100%; }
        .inputs { gap: 0.6rem; }
      }
    </style>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/retro.css">
  </head>
  <body>
    <div class="battle-container">
      <h1>Mona Mayhem</h1>
      <p>GitHub Contribution Battle Arena</p>
      <div class="inputs" role="group" aria-label="Player usernames">
        <label class="sr-only" for="player1">Player 1 GitHub username</label>
        <input id="player1" name="player1" type="text" placeholder="Player 1 GitHub username" autocomplete="off" aria-label="Player 1 GitHub username" />
        <label class="sr-only" for="player2">Player 2 GitHub username</label>
        <input id="player2" name="player2" type="text" placeholder="Player 2 GitHub username" autocomplete="off" aria-label="Player 2 GitHub username" />
        <button class="battle-btn" id="battle" type="button">Battle</button>
      </div>
      <div id="error" class="error" role="alert" aria-live="assertive" aria-atomic="true" style="display:none"></div>
      <div id="loading" class="loading" style="display:none">Loading...</div>
      <div class="results" id="results"></div>
    </div>
    <script type="module" src="/battle.js"></script>
  </body>
</html>
